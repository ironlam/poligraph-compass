# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# synced data (generated by npm run sync)
data/synced-data.json
docs/superpowers/

# Pipeline working files (contain API responses, not committed)
data/pipeline/candidates.json
data/pipeline/drafts.json
data/pipeline/*-audit-report.json
